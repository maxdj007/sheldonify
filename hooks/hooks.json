{
  "description": "Sheldonify lifecycle hooks — ensures sheldonify is available and validates operations",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/check-install.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
